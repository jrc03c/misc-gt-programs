--------------------------------------------------------------------------------
-- @jrc03c/email/standardize-email-address
--------------------------------------------------------------------------------
-- url          : https://www.guidedtrack.com/programs/34794/edit
-- tests        : https://www.guidedtrack.com/programs/34813/edit
-- author       : Josh Castle (joshrcastle@gmail.com)
-- all programs : https://github.com/jrc03c/misc-gt-programs
--------------------------------------------------------------------------------
-- ┌─────────────────────────────────────────────┬─────────────────────────────┐
-- │ INPUT 👉                                    │ DESCRIPTION                 │
-- ├─────────────────────────────────────────────┼─────────────────────────────┤
-- │ email_address*                              │ string; required;           │
-- │                                             │ default=""                  │
-- ├─────────────────────────────────────────────┼─────────────────────────────┤
-- │ should_convert_domain_to_punycode           │ binary; default=0           │
-- ├─────────────────────────────────────────────┼─────────────────────────────┤
-- │ should_remove_diacritical_marks_in_username │ binary; default=1           │
-- ├─────────────────────────────────────────────┼─────────────────────────────┤
-- │ should_remove_periods_in_username           │ binary; default=0           │
-- ├─────────────────────────────────────────────┼─────────────────────────────┤
-- │ should_remove_tags_in_username              │ binary; default=0           │
-- └─────────────────────────────────────────────┴─────────────────────────────┘
-- * indicates a required input
--------------------------------------------------------------------------------
-- ┌─────────────────────────────────────────────┬─────────────────────────────┐
-- │ OUTPUT 👈                                   │ DESCRIPTION                 │
-- ├─────────────────────────────────────────────┼─────────────────────────────┤
-- │ email_address_standardized                  │ string; default=""          │
-- ├─────────────────────────────────────────────┼─────────────────────────────┤
-- │ service_response                            │ association; default={}     │
-- └─────────────────────────────────────────────┴─────────────────────────────┘
--------------------------------------------------------------------------------

>> error_title = "@jrc03c/email/standardize-email-address"

*if: not email_address
	>> error_message = "You must define a variable called `email_address` that has a string value representing an email address!"
	*program: @jrc03c/show-error
	*goto: CleanUpLabelF69G1CFEA5605F12D774AE5D1449D7F9

*if: not (email_address.type = "string")
	>> error_message = "You must define a variable called `email_address` that has a string value representing an email address!"
	*program: @jrc03c/show-error
	*goto: CleanUpLabelF69G1CFEA5605F12D774AE5D1449D7F9

*if: not should_convert_domain_to_punycode
	>> should_convert_domain_to_punycode = 0

*if: not should_remove_diacritical_marks_in_username
	>> should_remove_diacritical_marks_in_username = 1

*if: not should_remove_periods_in_username
	>> should_remove_periods_in_username = 0

*if: not should_remove_tags_in_username
	>> should_remove_tags_in_username = 0

>> input = email_address
*program: @jrc03c/string/encode-uri-component
>> email_encoded = output

>> params = "email={email_encoded}"
>> params = "{params}&should_convert_domain_to_punycode={should_convert_domain_to_punycode}"
>> params = "{params}&should_remove_diacritical_marks_in_username={should_remove_diacritical_marks_in_username}"
>> params = "{params}&should_remove_periods_in_username={should_remove_periods_in_username}"
>> params = "{params}&should_remove_tags_in_username={should_remove_tags_in_username}"

>> service_response = {}
>> service_response["service"] = "ct-programs-vercel-app"
>> service_response["method"] = "GET"
>> service_response["path"] = "/utils/standardize-email-address?{params}"
>> temp = {}

*service: ct-programs-vercel-app
	*method: GET
	*path: /utils/standardize-email-address?{params}
	*success
		>> email_address_standardized = it["email"]
		>> temp = it
	*error
		>> temp = it

*for: key in temp.keys
	>> service_response[key] = temp[key]

--------------------------------------------------------------------------------

*label: CleanUpLabelF69G1CFEA5605F12D774AE5D1449D7F9

>> email_encoded = ""
>> error_message = ""
>> error_title = ""
>> input = ""
>> key = ""
>> output = ""
>> params = ""
>> should_convert_domain_to_punycode = ""
>> should_remove_diacritical_marks_in_username = ""
>> should_remove_periods_in_username = ""
>> should_remove_tags_in_username = ""
>> temp = ""